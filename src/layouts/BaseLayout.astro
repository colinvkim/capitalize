---
import { Font } from "astro:assets";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Capitalize Titles",
  description = "Format titles with style-guide-aware capitalization in a fast Astro app."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <Font cssVariable="--font-inter" preload />
  </head>
  <body>
    <slot />
  </body>
</html>
