---
import {
  CAPITALIZATION_MODE_OPTIONS,
  DEFAULT_CAPITALIZATION_MODE,
  DEFAULT_STYLE_GUIDE,
  STYLE_GUIDE_OPTIONS
} from "../lib/capitalize";
---

<section class="app-hero">
  <p class="eyebrow">Capitalize</p>
  <h1>Type title. App fixes caps live.</h1>
  <p class="lede">
    This tool rewrites your title as you type using title, sentence, upper, lower,
    first-letter, or alternating case rules.
  </p>
</section>

<section class="app-shell" data-capitalizer-app>
  <div class="simple-card">
    <div class="simple-head">
      <div>
        <p class="panel-label">Live field</p>
        <h2>One box in. One box out.</h2>
      </div>

      <button class="copy-button" type="button" data-copy-button disabled>
        Copy
      </button>
    </div>

    <label class="field">
      <span class="field-label">Title</span>
      <input
        class="live-input"
        data-title-input
        type="text"
        name="title"
        placeholder="type title here"
        autocomplete="off"
        spellcheck="false"
      />
    </label>

    <div class="control-stack">
      <div class="control-group">
        <div class="group-heading">
          <div>
            <p class="panel-label">Mode</p>
            <h3>Pick capitalization</h3>
          </div>
        </div>

        <div class="option-grid">
          {
            CAPITALIZATION_MODE_OPTIONS.map((option) => (
              <label class="option-pill">
                <input
                  type="radio"
                  name="capitalization-mode"
                  value={option.value}
                  checked={option.value === DEFAULT_CAPITALIZATION_MODE}
                />
                <span class="option-title">{option.label}</span>
              </label>
            ))
          }
        </div>
      </div>

      <div class="control-group">
        <div class="group-heading">
          <div>
            <p class="panel-label">Guide</p>
            <h3>Title case rules</h3>
          </div>
        </div>

        <div class="option-grid compact">
          {
            STYLE_GUIDE_OPTIONS.map((option) => (
              <label class="option-pill compact">
                <input
                  type="radio"
                  name="style-guide"
                  value={option.value}
                  checked={option.value === DEFAULT_STYLE_GUIDE}
                />
                <span class="option-title">{option.label}</span>
              </label>
            ))
          }
        </div>
      </div>
    </div>

    <div class="status-row">
      <p class="helper-text" data-guide-helper>
        Title case mode uses selected guide. Other modes ignore guide rules.
      </p>
      <p class="status-text" data-copy-status>Waiting for input</p>
    </div>
  </div>
</section>

<script>
  import {
    DEFAULT_CAPITALIZATION_MODE,
    DEFAULT_STYLE_GUIDE,
    isCapitalizationMode,
    isStyleGuide,
    transformTitle
  } from "../lib/capitalize";

  const root = document.querySelector("[data-capitalizer-app]");

  if (!root) {
    throw new Error("Capitalizer app root was not found.");
  }

  const titleInput = root.querySelector("[data-title-input]");
  const copyButton = root.querySelector("[data-copy-button]");
  const guideHelper = root.querySelector("[data-guide-helper]");
  const copyStatus = root.querySelector("[data-copy-status]");

  if (
    !(titleInput instanceof HTMLInputElement) ||
    !(copyButton instanceof HTMLButtonElement) ||
    !(guideHelper instanceof HTMLParagraphElement) ||
    !(copyStatus instanceof HTMLElement)
  ) {
    throw new Error("Capitalizer UI is missing required elements.");
  }

  let copyResetHandle = 0;
  let syncingValue = false;

  const getSelectedValue = (name: string) => {
    const selected = root.querySelector(`input[name="${name}"]:checked`);
    return selected instanceof HTMLInputElement ? selected.value : "";
  };

  const render = () => {
    const rawMode = getSelectedValue("capitalization-mode");
    const rawGuide = getSelectedValue("style-guide");
    const mode = isCapitalizationMode(rawMode)
      ? rawMode
      : DEFAULT_CAPITALIZATION_MODE;
    const guide = isStyleGuide(rawGuide) ? rawGuide : DEFAULT_STYLE_GUIDE;
    const selectionStart = titleInput.selectionStart;
    const selectionEnd = titleInput.selectionEnd;
    const formatted = transformTitle(titleInput.value, mode, guide);
    const hasValue = formatted.length > 0;

    if (titleInput.value !== formatted) {
      syncingValue = true;
      titleInput.value = formatted;

      if (
        document.activeElement === titleInput &&
        selectionStart !== null &&
        selectionEnd !== null
      ) {
        titleInput.setSelectionRange(selectionStart, selectionEnd);
      }

      syncingValue = false;
    }

    copyButton.disabled = !hasValue;
    guideHelper.textContent =
      mode === "title-case"
        ? "Selected guide shaping title live."
        : "Guide idle until you switch back to Title Case.";

    if (!hasValue) {
      copyStatus.textContent = "Waiting for input";
    }
  };

  titleInput.addEventListener("input", () => {
    if (syncingValue) {
      return;
    }

    render();
  });

  root.querySelectorAll('input[type="radio"]').forEach((input) => {
    input.addEventListener("change", render);
  });

  copyButton.addEventListener("click", async () => {
    if (copyButton.disabled) {
      return;
    }

    try {
      await navigator.clipboard.writeText(titleInput.value);
      copyButton.textContent = "Copied";
      copyStatus.textContent = "Copied to clipboard";
      window.clearTimeout(copyResetHandle);
      copyResetHandle = window.setTimeout(() => {
        copyButton.textContent = "Copy";
        copyStatus.textContent = "Ready to copy again";
      }, 1800);
    } catch {
      copyStatus.textContent = "Clipboard access failed";
    }
  });

  render();
</script>
